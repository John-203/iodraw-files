{"root":{"data":{"id":"dh5uo55btkg0","created":1773831168457,"text":"互动游戏"},"children":[{"data":{"id":"dh5uptmljhc0","created":1773831300108,"text":"整体定位"},"children":[{"data":{"id":"dh5upj5tf6g0","created":1773831277325,"text":"单人游玩、小体量、末世避难所背景、以角色关系互动为核心、带轻度经营压力的叙事模拟游戏。"},"children":[]}]},{"data":{"id":"dh5uqc9k7g00","created":1773831340678,"text":"核心设计目标"},"children":[{"data":{"id":"dh5uqjv0jog0","created":1773831357213,"text":"分支主题"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}