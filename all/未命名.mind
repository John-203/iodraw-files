{"root":{"data":{"id":"dh5uo55btkg0","created":1773831168457,"text":"互动游戏","expandState":"expand"},"children":[{"data":{"id":"dh5uqn6qr9s0","created":1773831364453,"text":"游戏舞台","layout_right_offset":{"x":1.7500002905726433,"y":63.49999976158148},"expandState":"expand"},"children":[{"data":{"id":"dh5uqqp82y00","created":1773831372100,"text":"避难所","expandState":"expand"},"children":[]}]},{"data":{"id":"dh5uqwyw99c0","created":1773831385746,"text":"基础循环结构","layout_right_offset":{"x":-28.749999143183004,"y":253.24999449402105},"expandState":"expand"},"children":[{"data":{"id":"dh5uqyk6es80","created":1773831389210,"text":"以“一天”为主要循环单位","expandState":"expand"},"children":[{"data":{"id":"dh5ur2ng2dk0","created":1773831398114,"text":"强制性社交环境","expandState":"expand"},"children":[]},{"data":{"id":"dh5ur5j271s0","created":1773831404379,"text":"自由性社交环境","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dh5urfvu2mw0","created":1773831426920,"text":"互动主要来源","layout_right_offset":{"x":-7.9999998807907104,"y":278.4999940246345},"expandState":"expand"},"children":[{"data":{"id":"dh5urip9aao0","created":1773831433052,"text":"对话","expandState":"expand"},"children":[]},{"data":{"id":"dh5urkk6nfk0","created":1773831437099,"text":"资源交换","expandState":"expand"},"children":[]}]},{"data":{"id":"dh5usyup00g0","created":1773831546574,"text":"角色系统的核心思想","expandState":"expand","layout_right_offset":{"x":-7.0000001937150955,"y":298.7499933317305}},"children":[{"data":{"id":"dh5ut33nhoo0","created":1773831555823,"text":"玩家与 NPC 的基础行为能力尽量相似","expandState":"expand"},"children":[]},{"data":{"id":"dh5ut5i33pk0","created":1773831561049,"text":"即使没有玩家，系统理论上也应能够继续运转","expandState":"expand"},"children":[]},{"data":{"id":"dh5utb48kbc0","created":1773831573272,"text":"NPC 会根据自身性格、关系、状态与环境进行决策","expandState":"expand"},"children":[]},{"data":{"id":"dh5utinsfwg0","created":1773831589692,"text":"性格机制的定位","expandState":"expand"},"children":[{"data":{"id":"dh5utmhq15s0","created":1773831598032,"text":"性格决定角色更倾向于怎样互动","expandState":"expand"},"children":[]},{"data":{"id":"dh5utrj4zio0","created":1773831609002,"text":"性格会影响角色偏好的互动对象","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dh5utvqi19c0","created":1773831618154,"text":"综述","layout_right_offset":{"x":47.24999905377615,"y":-424.0000073462722},"expandState":"expand"},"children":[{"data":{"id":"dh5uptmljhc0","created":1773831300108,"text":"整体定位","expandState":"expand"},"children":[{"data":{"id":"dh5upj5tf6g0","created":1773831277325,"text":"单人游玩、小体量、末世避难所背景、以角色关系互动为核心、带轻度经营压力的叙事模拟游戏。","expandState":"expand"},"children":[]}]},{"data":{"id":"dh5uqc9k7g00","created":1773831340678,"text":"核心设计目标","expandState":"expand"},"children":[{"data":{"id":"dh5uqjv0jog0","created":1773831357213,"text":"用尽量少的玩家输入，驱动一个较复杂但被封装起来的角色互动系统。","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dh5uv4myb3k0","created":1773831715895,"text":"玩家特殊性","expandState":"expand","layout_right_offset":{"x":-2.499999925494194,"y":136.24999593943357}},"children":[{"data":{"id":"dh5uv7xkzw80","created":1773831723068,"text":"玩家可以更自由地选择互动对象","expandState":"expand"},"children":[]},{"data":{"id":"dh5uvc57bq80","created":1773831732236,"text":"玩家可以从反馈中推测他人感情与关系变化","expandState":"expand"},"children":[]},{"data":{"id":"dh5uvfjb3xc0","created":1773831739619,"text":"玩家可以不完全按照所扮演角色的既有性格行动，但系统应通过某种方式鼓励合理角色扮演","expandState":"expand"},"children":[]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}