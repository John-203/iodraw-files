{"root":{"data":{"id":"dh5uo55btkg0","created":1773831168457,"text":"互动游戏"},"children":[{"data":{"id":"dh5uptmljhc0","created":1773831300108,"text":"整体定位"},"children":[{"data":{"id":"dh5upj5tf6g0","created":1773831277325,"text":"单人游玩、小体量、末世避难所背景、以角色关系互动为核心、带轻度经营压力的叙事模拟游戏。"},"children":[]}]},{"data":{"id":"dh5uqc9k7g00","created":1773831340678,"text":"核心设计目标","expandState":"expand"},"children":[{"data":{"id":"dh5uqjv0jog0","created":1773831357213,"text":"用尽量少的玩家输入，驱动一个较复杂但被封装起来的角色互动系统。"},"children":[]}]},{"data":{"id":"dh5uqn6qr9s0","created":1773831364453,"text":"游戏舞台"},"children":[{"data":{"id":"dh5uqqp82y00","created":1773831372100,"text":"避难所"},"children":[]}]},{"data":{"id":"dh5uqwyw99c0","created":1773831385746,"text":"基础循环结构"},"children":[{"data":{"id":"dh5uqyk6es80","created":1773831389210,"text":"以“一天”为主要循环单位"},"children":[{"data":{"id":"dh5ur2ng2dk0","created":1773831398114,"text":"强制性社交环境"},"children":[]},{"data":{"id":"dh5ur5j271s0","created":1773831404379,"text":"自由性社交环境"},"children":[]}]}]},{"data":{"id":"dh5urfvu2mw0","created":1773831426920,"text":"互动主要来源"},"children":[{"data":{"id":"dh5urip9aao0","created":1773831433052,"text":"对话"},"children":[]},{"data":{"id":"dh5urkk6nfk0","created":1773831437099,"text":"资源交换"},"children":[]}]},{"data":{"id":"dh5usyup00g0","created":1773831546574,"text":"角色系统的核心思想"},"children":[{"data":{"id":"dh5ut33nhoo0","created":1773831555823,"text":"玩家与 NPC 的基础行为能力尽量相似"},"children":[]},{"data":{"id":"dh5ut5i33pk0","created":1773831561049,"text":"即使没有玩家，系统理论上也应能够继续运转"},"children":[]},{"data":{"id":"dh5utb48kbc0","created":1773831573272,"text":"分支主题"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}